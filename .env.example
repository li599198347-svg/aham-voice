# Copy this file to `.env` in the same directory and fill in real values.
# Never commit `.env` — it is in .gitignore.

# Where the app stores models, recordings, exports, sqlite, etc.
# Default: ~/.cache/recording-ai
RECORDING_AI_HOME=/Users/<you>/.cache/recording-ai

# ---------- DeepSeek (云端纪要生成) ----------
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# ---------- 可选：调优 ----------
# AHAMVOICE_UPLOAD_MAX_MB=2048           # 上传文件大小上限（默认 2GB）
# AHAMVOICE_TMP_TTL_HOURS=24              # tmp 文件清理 TTL
# AHAMVOICE_EXPORT_TTL_DAYS=14            # 导出文件清理 TTL
# AHAMVOICE_SWEEP_INTERVAL_MINUTES=60     # 清理周期
# AHAMVOICE_HOTWORD_LIMIT=3000            # ASR 热词上限
# AHAMVOICE_VOICEPRINT_THRESHOLD=0.66     # 声纹默认匹配阈值
# AHAMVOICE_INITIAL_PASSWORD=changeme   # 单用户桌面版用不到；保留仅为兼容